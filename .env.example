# ─── Clerk Auth ───────────────────────────────────────────────────────────────
# From Clerk Dashboard → API Keys
VITE_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# ─── Turso Database ───────────────────────────────────────────────────────────
# From Turso Dashboard (libsql://...)
TURSO_DATABASE_URL="libsql://your-db.turso.io"
TURSO_AUTH_TOKEN="your-turso-auth-token"

# ─── AI Models ────────────────────────────────────────────────────────────────
# At least GEMINI_API_KEY is required (default model)
GEMINI_API_KEY="your-gemini-api-key"
# Optional — required only if business owners select these models
OPENAI_API_KEY="sk-..."
GROK_API_KEY="xai-..."

# ─── Payment Gateways ─────────────────────────────────────────────────────────
# Paystack — for Nigerian businesses (NGN)
PAYSTACK_SECRET_KEY="sk_test_..."
# Flutterwave — for African/multi-currency businesses
FLUTTERWAVE_SECRET_HASH="your-flutterwave-secret-hash"
# Stripe — for international businesses (USD/EUR/GBP)
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_SECRET_KEY="sk_test_..."

# ─── Google OAuth (Calendar + Meet) ──────────────────────────────────────────
# From Google Cloud Console → OAuth 2.0 Credentials
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
# Must match exactly what's set in Google Cloud Console
GOOGLE_REDIRECT_URI="https://your-app.vercel.app/api/google-auth"

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# From resend.com → API Keys
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@yourdomain.com"

# ─── App Config ───────────────────────────────────────────────────────────────
APP_URL="https://your-app.vercel.app"
# Admin email — this user gets access to the Admin Panel
ADMIN_EMAIL="your-admin@email.com"
NODE_ENV="production"
